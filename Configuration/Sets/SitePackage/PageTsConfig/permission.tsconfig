TCEMAIN.permissions {
    # ID of the backend user that will own new pages
    userid = {$T3SitepackageComeun1ty.userIdForNewPages}
    # ID of the backend group that will own new pages
    groupid = {$T3SitepackageComeun1ty.groupIdForNewPages}
    # Optional: Explicitly set permissions for user and group
    user = show, editcontent, edit, delete, new
    group = show, editcontent, edit, new
}