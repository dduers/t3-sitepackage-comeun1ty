page = PAGE
page {

    10 = PAGEVIEW
    10 {
        paths {
            0 = EXT:t3_sitepackage_comeun1ty/Resources/Private/
            10 = {$T3SitepackageComeun1ty.templateRootPath}
        }
        dataProcessing {
            # makes content elements available as {content} in Fluid template
            10 = page-content
        }
    }

    shortcutIcon = {$T3SitepackageComeun1ty.favicon}
}